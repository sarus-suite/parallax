{
  "name": "Parallax Ubuntu",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "GO_VERSION": "1.24.0"
    }
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "postCreateCommand": "go mod download",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ]
    }
  }
}
